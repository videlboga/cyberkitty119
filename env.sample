# Cyberkitty19 Transkribator - Переменные окружения
# Скопируйте этот файл в .env и заполните своими значениями

# ===== ОСНОВНЫЕ НАСТРОЙКИ TELEGRAM БОТА =====
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ===== НАСТРОЙКИ ДЛЯ ЛОКАЛЬНОГО BOT API SERVER =====
TELEGRAM_API_ID=21532963
TELEGRAM_API_HASH=66e38ebc131425924c2680e6c8fb6c09

# ===== API КЛЮЧИ ДЛЯ ТРАНСКРИБАЦИИ И ФОРМАТИРОВАНИЯ =====
# OpenAI API (для GPT моделей)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API (для Claude, Gemini и других моделей)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Preferred models for embeddings and LLM via OpenRouter (optional)
OPENROUTER_EMBED_MODEL=text-embedding-3-small
OPENROUTER_LLM_MODEL=gpt-4o-mini

# Beta mode and router configuration
FEATURE_BETA_MODE=true
ROUTER_MODEL=google/gemini-2.5-flash-lite
ROUTER_CONF_HIGH=0.80
ROUTER_CONF_MID=0.55
SEARCH_BACKEND=pgvector
ENABLE_STRUCT_LOGS=0
FEATURE_GOOGLE_CALENDAR=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_ENCRYPTION_KEY=change_me_to_random_32_bytes

# DeepInfra API (альтернативный провайдер)
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# Replicate API (для Whisper транскрибации)
REPLICATE_API_TOKEN=your_replicate_token_here
REPLICATE_WHISPER_MODEL=carnifexer/whisperx
REPLICATE_WHISPER_DIARIZATION_MODEL=thomasmol/whisper-diarization

# ===== НАСТРОЙКИ БАЗЫ ДАННЫХ =====
# Пример для SQLite (локально)
DATABASE_URL=sqlite:///./cyberkitty19-transkribator.db

# Пример для PostgreSQL (боевой/стейджинг)
# DATABASE_URL=postgresql+psycopg://user:password@postgres:5432/transkribator

# Core API (headless backend) базовый URL и таймаут
CORE_API_BASE_URL=http://core-api:8000/api/v1
CORE_API_TIMEOUT=15
CORE_API_SERVICE_TOKEN=change_me_service_token

# ===== REDIS / STATE STORAGE =====
REDIS_URL=redis://localhost:6379/0

# ===== МОНИТОРИНГ И УВЕДОМЛЕНИЯ =====
# Chat ID для отправки уведомлений о проблемах (опционально)
HEALTH_CHECK_CHAT_ID=your_admin_chat_id_here

# ===== ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ =====
# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Максимальный размер файла для прямой загрузки (в МБ)
MAX_DIRECT_DOWNLOAD_SIZE=20 

# Если установлено в 1/true/yes, заставляет адаптер di_worker делегировать
# транскрибацию локальному HTTP-сервису Whisper (полезно для разработки).
DI_WORKER_FORCE_LOCAL=0

# OpenRouter / LLM + embeddings (optional; if empty the services run in mock/offline mode)
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://api.openrouter.ai
OPENROUTER_EMBED_MODEL=text-embedding-3-small
OPENROUTER_LLM_MODEL=gpt-4o-mini
EMBED_PROVIDER=openrouter
LLM_PROVIDER=openrouter

# ===== ЛОКАЛЬНЫЙ WHISPER (transcribe_client) =====
# Включает использование локального клиента (например, HTTP Whisper или di_worker) перед удалёнными сервисами.
TRANSCRIBE_CLIENT_ENABLED=1
# Режим по умолчанию: local | di_worker | auto | stub
TRANSCRIBE_DEFAULT_MODE=local
# URL локального сервиса Whisper (используется client.local)
WHISPER_SERVICE_URL=http://real-whisper:8000
